---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import SectionHead from "@components/portfolio/SectionHead.astro";
import ProjectCard from "@components/portfolio/ProjectCard.astro";
import Doodles from "@components/portfolio/Doodles.astro";
import InknoteMock from "@components/portfolio/mocks/InknoteMock.astro";
import { SITE } from "@utils/site";

const socials = SITE.socials;

const projects = [
  {
    name: "Inknote",
    slug: "inknote",
    tag: "a notes app that thinks like a whiteboard",
    year: "2025",
    paperBg: "#e8e6dc",
    rotate: -1.2,
    href: "https://www.inknote.net/",
    Mock: InknoteMock,
  },
  // {
  //   name: "Tide",
  //   slug: "tide",
  //   tag: "surf forecasts for the baja coast",
  //   year: "2024",
  //   paperBg: "#dfe6ec",
  //   rotate: 0.8,
  //   Mock: TideMock,
  // },
  // {
  //   name: "Paw",
  //   slug: "paw",
  //   tag: "walk tracker for households with too many dogs",
  //   year: "2024",
  //   paperBg: "#f1ebe2",
  //   rotate: -0.6,
  //   Mock: PawMock,
  // },
  // {
  //   name: "Fretline",
  //   slug: "fretline",
  //   tag: "guitar tabs that follow along while you play",
  //   year: "2023",
  //   paperBg: "#e6e3da",
  //   rotate: 1.4,
  //   Mock: FretlineMock,
  // },
];

const posts = (await getCollection("posts"))
  .filter((p) => !p.data.draft || import.meta.env.DEV)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((p) => ({
    id: p.id,
    ...p.data,
    date: p.data.date
      .toLocaleString("en-US", { month: "short", day: "2-digit" })
      .toLowerCase(),
  }));
---

<Layout>
  <main class="page" style="position: relative; min-height: 100vh;">
    <div class="reveal reveal-1" style="position: relative;">
      <div
        class="mono"
        style="font-size: 11.5px; color: var(--ink-3); letter-spacing: .05em; margin-bottom: 18px;"
      >
        kenneth · loreto, baja sur
      </div>
      <p
        style="font-size: 17px; line-height: 1.55; margin: 0; color: var(--ink); max-width: 460px; text-wrap: pretty;"
      >
        hi i'm kenneth, i build software, play around with design and{" "}
        <span
          style="position: relative; background: linear-gradient(transparent 65%, var(--orange-soft) 65%); padding-inline: 2px;"
          >occasionally</span
        >{" "} write things down. but most of my time is finding something cool
        to make and try different stuff until it works.
      </p>
    </div>

    <!-- Social Links -->
    <div class="reveal reveal-2" style="position: relative;">
      <div
        style="display: flex; flex-wrap: wrap; gap: 14px 18px; margin-top: 32px;"
      >
        {
          socials.map((l) => (
            <a href={l.href} class="social-link" target="_blank">
              {l.label}
              <svg
                width="9"
                height="9"
                viewBox="0 0 9 9"
                style="display: inline-block; margin-left: 3px; vertical-align: baseline;"
                aria-hidden="true"
              >
                <path
                  d="M2 1 H8 V7 M8 1 L1 8"
                  stroke="currentColor"
                  stroke-width="1"
                  fill="none"
                  stroke-linecap="round"
                />
              </svg>
            </a>
          ))
        }
      </div>
      <Doodles />
    </div>

    <!-- Projects -->
    <section class="reveal reveal-3" style="margin-top: 88px;">
      <SectionHead label="projects" mark={`${projects.length} things`} />
      <div class="projects-grid">
        {
          projects.map((p) => {
            const Mock = p.Mock;
            return (
              <ProjectCard
                name={p.name}
                tag={p.tag}
                year={p.year}
                paperBg={p.paperBg}
                rotate={p.rotate}
                href={p.href}
              >
                <Mock />
              </ProjectCard>
            );
          })
        }
      </div>
    </section>

    <section
      id="writing"
      class="reveal reveal-4"
      style="margin-top: 88px;"
    >
      <SectionHead label="writing" mark={`${posts.length} posts`} />
      <div style="display: flex; flex-direction: column;">
        {
          posts.map((p) => (
            <a href={`/posts/${p.id}`} class="post-row">
              <span
                class="post-title"
                style="font-size: 14.5px; transition: color .25s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
              >
                <span class="arrow">→</span>
                {p.title}
              </span>
              <span
                class="mono"
                style="font-size: 11px; color: var(--ink-3);"
              >
                {p.read}
              </span>
              <span
                class="mono"
                style="font-size: 11px; color: var(--ink-3); min-width: 50px; text-align: right;"
              >
                {p.date}
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <footer
      class="reveal reveal-5"
      style="margin-top: 96px; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;"
    >
      <div class="mono" style="font-size: 11px; color: var(--ink-3);">
        <span
          style="display: inline-block; width: 6px; height: 6px; border-radius: 6px; background: var(--orange); margin-right: 6px; vertical-align: middle;"
        ></span>
        available for work
      </div>
    </footer>
  </main>
</Layout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  @media (max-width: 520px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
