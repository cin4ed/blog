---
import Layout from "@layouts/Layout.astro";
import roamrImage from "@assets/images/roamr-project-image.png";
import { Picture } from "astro:assets";
import SectionHead from "@components/portfolio/SectionHead.astro";
---

<Layout>
  <main class="page" style="position: relative; min-height: 100vh;">
    <header
      style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 32px;"
    >
      <h1 style="font-size: 17px; font-weight: 500; margin: 0;">roamr</h1>
      <a href="/" class="home-link" style="font-size: 13px;">← home</a>
    </header>

    <section
      style="display: flex; flex-direction: column; align-items: center; gap: 12px;"
    >
      <div
        class="sticky-frame"
        style="--paper-bg: #e8e6dc; padding: 16px; transform: rotate(-1.2deg); display: inline-block;"
      >
        <Picture
          alt="Roamr project image"
          src={roamrImage}
          formats={["avif"]}
          width={800}
          height={800}
          style="display: block; max-width: 100%; height: auto; width: 320px;"
        />
      </div>
      <p
        class="mono"
        style="font-size: 12.5px; color: var(--ink-2); margin: 8px 0 0;"
      >
        urban exploration community map
      </p>
    </section>

    <div
      style="margin-top: 24px; display: flex; gap: 18px; flex-wrap: wrap;"
    >
      <a
        href="https://github.com/cin4ed/roamr"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link">view on github</a
      >
    </div>

    <section style="margin-top: 64px;">
      <SectionHead label="about" />
      <p style="margin: 0; color: var(--ink); max-width: 520px;">
        Roamr is a community-driven platform for urban explorers to discover and
        share abandoned places around the world. It features an interactive map
        interface where users can find forgotten locations, read their
        histories, and contribute their own discoveries. The platform emphasizes
        safety and responsible exploration while preserving the stories of these
        abandoned spaces.
      </p>
    </section>

    <section style="margin-top: 48px;">
      <SectionHead label="nerd notes" />
      <p style="margin: 0; color: var(--ink); max-width: 520px;">
        Built this with Next.js, TypeScript, and Supabase. The mapping is
        powered by MapLibre and OpenStreetMap, which was a blast to work with.
        The trickiest part was handling location data responsibly – balancing
        accessibility with privacy concerns for sensitive locations. Currently
        working on the community features like ratings and photo galleries. It's
        still a work in progress, but I'm excited about where it's headed!
      </p>
    </section>
  </main>
</Layout>
