---
import Layout from "@layouts/Layout.astro";
import { Picture } from "astro:assets";
import projectImage from "@assets/images/enfa-project-image.png";
import SectionHead from "@components/portfolio/SectionHead.astro";
---

<Layout>
  <main class="page" style="position: relative; min-height: 100vh;">
    <header
      style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 32px;"
    >
      <h1 style="font-size: 17px; font-weight: 500; margin: 0;">enfá</h1>
      <a href="/" class="home-link" style="font-size: 13px;">← home</a>
    </header>

    <section
      style="display: flex; flex-direction: column; align-items: center; gap: 12px;"
    >
      <div
        class="sticky-frame"
        style="--paper-bg: #dfe6ec; padding: 16px; transform: rotate(0.8deg); display: inline-block;"
      >
        <Picture
          alt="Enfá project image"
          src={projectImage}
          formats={["avif"]}
          width={800}
          height={800}
          style="display: block; max-width: 100%; height: auto; width: 320px;"
        />
      </div>
      <p
        class="mono"
        style="font-size: 12.5px; color: var(--ink-2); margin: 8px 0 0;"
      >
        food delivery for my town
      </p>
    </section>

    <div
      style="margin-top: 24px; display: flex; gap: 18px; flex-wrap: wrap;"
    >
      <a href="/" class="social-link">visit website</a>
    </div>

    <section style="margin-top: 64px;">
      <SectionHead label="about" />
      <p style="margin: 0; color: var(--ink); max-width: 520px;">
        Enfá is a food delivery app I made for my town. It allows you to order
        food from local restaurants and have it delivered to your door.
      </p>
    </section>

    <section style="margin-top: 48px;">
      <SectionHead label="nerd notes" />
      <p style="margin: 0; color: var(--ink); max-width: 520px;">
        Enfá comes from "En fá" which means "to make it fast", it´s
        spanish-english slang that has something to do with the word "fast", any
        way. I built this app because I was tired of my mom sending me to get
        her ceviche from the local restaurant, and also because my town is too
        small that major delivery apps wouldn't cover it.
      </p>
    </section>
  </main>
</Layout>
