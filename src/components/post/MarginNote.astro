---
interface Props {
  top?: string;
}
const { top = "280px" } = Astro.props;
---

<aside class="margin-note" style={`top: ${top};`}>
  <svg class="hand-arrow" viewBox="0 0 50 30" aria-hidden="true">
    <path
      d="M48 18 Q 32 24, 18 14 Q 10 8, 4 12"
      stroke="#044e9c"
      stroke-width="1.4"
      fill="none"
      stroke-linecap="round"></path>
    <path
      d="M2 8 L4 13 L9 12"
      stroke="#044e9c"
      stroke-width="1.4"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
  <slot />
</aside>
