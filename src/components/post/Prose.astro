---
---

<div class="prose">
  <slot />
</div>

<style is:global>
  .prose {
    margin-top: 36px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
  }
  .prose > p,
  .prose > ul,
  .prose > ol {
    margin: 0 0 22px;
    text-wrap: pretty;
  }
  .prose > p:has(+ pre),
  .prose > p:has(+ blockquote),
  .prose > p:has(+ figure),
  .prose > p:has(+ h2) {
    margin-bottom: 28px;
  }
  .prose strong {
    font-weight: 600;
  }
  .prose em {
    font-style: italic;
  }
  .prose a {
    color: var(--ink);
    text-decoration: none;
    background-image: linear-gradient(
      transparent 62%,
      rgba(4, 78, 156, 0.18) 62%,
      rgba(4, 78, 156, 0.18) 92%,
      transparent 92%
    );
    transition:
      background-image 0.25s,
      color 0.25s;
    padding: 0 1px;
  }
  .prose a:hover {
    color: var(--blue);
    background-image: linear-gradient(
      transparent 62%,
      rgba(4, 78, 156, 0.32) 62%,
      rgba(4, 78, 156, 0.32) 92%,
      transparent 92%
    );
  }

  .prose h2 {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 44px 0 16px;
    line-height: 1.25;
    position: relative;
  }
  .prose h2::before {
    content: "";
    position: absolute;
    left: -22px;
    top: 14px;
    width: 12px;
    height: 1px;
    background: var(--orange);
  }
  .prose h3 {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin: 32px 0 12px;
    line-height: 1.3;
  }

  .prose ul,
  .prose ol {
    padding-left: 22px;
  }
  .prose li {
    margin-bottom: 6px;
  }
  .prose li::marker {
    color: var(--ink-3);
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 32px 0;
  }

  .prose img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 24px auto;
    border-radius: 2px;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .prose blockquote {
    margin: 32px 0 32px -8px;
    padding: 4px 0 4px 18px;
    border-left: 2px solid var(--blue);
    font-size: 19px;
    line-height: 1.45;
    color: var(--ink);
    font-weight: 400;
    letter-spacing: -0.005em;
    text-wrap: balance;
  }
  .prose blockquote p {
    margin: 0;
  }
  .prose blockquote .src {
    display: block;
    margin-top: 10px;
    font-family: "Geist Mono", monospace;
    font-size: 11.5px;
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }

  .prose :not(pre) > code {
    font-family: "Geist Mono", monospace;
    font-size: 13.5px;
    background: rgba(4, 78, 156, 0.08);
    color: var(--blue);
    padding: 1px 6px;
    border-radius: 3px;
    border: 1px solid rgba(4, 78, 156, 0.12);
  }

  /* expressive-code frame already has its own padding/shadow */
  .prose .expressive-code {
    margin: 8px -8px 28px;
  }

  .prose .hl {
    background: linear-gradient(transparent 60%, var(--paper-orange) 60%);
    padding: 0 2px;
  }

  .prose figure.diagram {
    margin: 32px -16px;
    padding: 22px 18px 18px;
    background: var(--paper-yellow);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow:
      0 6px 18px -8px rgba(0, 0, 0, 0.18),
      0 2px 4px rgba(0, 0, 0, 0.06);
    transform: rotate(-0.4deg);
    border-radius: 2px;
    position: relative;
  }
  .prose figure.diagram .pin {
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 50px;
    height: 14px;
    background: rgba(4, 78, 156, 0.4);
    border-left: 1px dashed rgba(0, 0, 0, 0.1);
    border-right: 1px dashed rgba(0, 0, 0, 0.1);
  }
  .prose figure.diagram figcaption {
    margin-top: 10px;
    font-family: "Caveat", cursive;
    font-size: 16px;
    color: var(--ink-2);
    text-align: center;
  }

  .prose sup.fn {
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    color: var(--orange);
    margin-left: 1px;
  }
  .prose sup.fn a {
    color: var(--orange);
    background: none;
    text-decoration: none;
  }

  .prose .footnotes {
    margin-top: 56px;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
    font-size: 13.5px;
    color: var(--ink-2);
  }
  .prose .footnotes ol {
    padding-left: 18px;
    margin: 0;
  }
  .prose .footnotes li {
    margin-bottom: 8px;
  }
  .prose .footnotes li::marker {
    color: var(--orange);
    font-family: "Geist Mono", monospace;
    font-size: 11px;
  }

  .prose aside.margin-note {
    position: absolute;
    right: -200px;
    width: 170px;
    font-family: "Caveat", cursive;
    font-size: 17px;
    line-height: 1.25;
    color: var(--blue);
  }
  .prose aside.margin-note .hand-arrow {
    display: block;
    width: 50px;
    margin-bottom: 4px;
  }
  @media (max-width: 1100px) {
    .prose aside.margin-note {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .prose .expressive-code {
      margin-left: 0;
      margin-right: 0;
    }
    .prose figure.diagram {
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>
