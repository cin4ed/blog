---
const bars = [3, 5, 8, 12, 9, 6, 4, 3, 5, 7, 11, 14, 10, 7, 5];
const days = ["mon", "tue", "wed", "thu", "fri", "sat", "sun"];
---

<div
  style='position: absolute; inset: 0; padding: 18px; font-family: "Geist", sans-serif; overflow: hidden; color: #2a2a2a;'
>
  <div
    style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px;"
  >
    <div style="font-weight: 500; font-size: 12px;">loreto · 7am</div>
    <div
      style='font-family: "Geist Mono", monospace; font-size: 10px; color: #7a7a7a;'
    >
      14 day
    </div>
  </div>

  <div
    style="display: flex; align-items: baseline; gap: 6px; margin-bottom: 4px;"
  >
    <div
      style="font-size: 36px; font-weight: 300; letter-spacing: -0.02em; line-height: 1;"
    >
      4.2<span style="font-size: 14px; color: #8a8a8a;">ft</span>
    </div>
    <div
      style='font-family: "Geist Mono", monospace; font-size: 9.5px; color: #ea833e; font-weight: 500;'
    >
      ↑ clean
    </div>
  </div>
  <div
    style='font-family: "Geist Mono", monospace; font-size: 9.5px; color: #7a7a7a; margin-bottom: 12px;'
  >
    nw swell · 11s · 6mph offshore
  </div>

  <div
    style="display: flex; align-items: flex-end; gap: 3px; height: 48px; border-bottom: 1px solid #d4d4d2;"
  >
    {
      bars.map((h, i) => (
        <div
          style={`flex: 1; height: ${(h / 14) * 100}%; background: ${i === 11 ? "#ea833e" : "#3a3a3a"}; opacity: ${i === 11 ? 1 : 0.85}; border-radius: 1.5px 1.5px 0 0;`}
        />
      ))
    }
  </div>
  <div
    style='display: flex; justify-content: space-between; font-family: "Geist Mono", monospace; font-size: 8px; color: #9a9a9a; margin-top: 4px;'
  >
    {days.map((d) => <span>{d}</span>)}
  </div>
</div>
